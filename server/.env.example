# Server Environment Variables Configuration
PORT=5000
CLIENT_URL=http://localhost:3000

# Clerk Authentication Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key
CLERK_WEBHOOK_SIGNING_SECRET=your_clerk_webhook_signing_secret

# Database URI
MONGO_URI=mongodb://localhost:27017/codearena

# Judge0 Sandboxed Execution API
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your_rapidapi_judge0_key

# Redis Configuration (Optional for Rate Limiting, State Management, and BullMQ queues)
# REDIS_URL=redis://127.0.0.1:6379
